; Core built-in coverage test for Devore.
; Run with: ./gradlew run --args=examples/core_test.devore

(def total 0)
(def passed 0)
(def failed 0)
(def skipped 0)

(def (pass name)
    (begin
        (set! total (+ total 1))
        (set! passed (+ passed 1))
        (println "[PASS] " name)))

(def (fail name detail)
    (begin
        (set! total (+ total 1))
        (set! failed (+ failed 1))
        (println "[FAIL] " name " :: " detail)))

(def (skip name detail)
    (begin
        (set! skipped (+ skipped 1))
        (println "[SKIP] " name " :: " detail)))

(def-macro (check= name expr expected)
    (try
        (let ([actual expr]
              [want expected])
            (if (= actual want)
                (pass name)
                (fail name (++ "expected " want ", got " actual))))
        (catch e
            (fail name (++ "unexpected error: " e)))))

(def-macro (check-near name expr expected eps)
    (try
        (let ([actual expr]
              [want expected])
            (if (<= (abs (- actual want)) eps)
                (pass name)
                (fail name (++ "expected near " want ", got " actual ", eps " eps))))
        (catch e
            (fail name (++ "unexpected error: " e)))))

(def-macro (check-true name expr)
    (try
        (if expr
            (pass name)
            (fail name "expected true"))
        (catch e
            (fail name (++ "unexpected error: " e)))))

(def-macro (check-error name expr)
    (try
        (let ([actual expr])
            (fail name (++ "expected error, got " actual)))
        (catch e
            (pass (++ name " caught: " e)))))

(println "== Devore Core test ==")

; Arithmetic and NumberUtils wrappers.
(check= "+ variadic" (+ 1 2 3 4) 10)
(check= "- unary" (- 7) -7)
(check= "- variadic" (- 20 3 4) 13)
(check= "* variadic" (* 2 3 4) 24)
(check= "/ exact" (/ 81 9) 9)
(check-near "/ repeating" (/ 1 3) 0.3333333333333333333333333333333333 0.000000000000000000000000000001)
(check= "pow integer" (pow 2 10) 1024)
(check= "pow negative integer" (pow 2 -3) 0.125)
(check= "pow rational exact" (pow 27 0.3333333333333333) 3)
(check= "average" (average 2 4 6 8) 5)
(check= "mod" (mod 17 5) 2)
(check= "rem negative dividend" (rem -17 5) -2)
(check= "abs" (abs -42.5) 42.5)
(check= "sqrt exact" (sqrt 144) 12)
(check-near "sqrt approximate" (sqrt 2) 1.4142135623730950488 0.000000000000000001)
(check= "cbrt positive exact" (cbrt 125) 5)
(check= "cbrt negative exact" (cbrt -27) -3)
(check= "gcd variadic" (gcd 84 30 18) 6)
(check= "lcm variadic" (lcm 4 6 10) 60)
(check= "prime? default certainty" (prime? 17) true)
(check= "prime? explicit certainty" (prime? 21 30) false)
(check= "log natural of 1" (log 1) 0)
(check= "log base 2" (log 8 2) 3)
(check-near "exp 0" (exp 0) 1 0.000000000000000001)
(check= "ceiling" (ceiling 2.1) 3)
(check= "floor" (floor 2.9) 2)
(check= "truncate positive" (truncate 2.9) 2)
(check= "truncate negative" (truncate -2.9) -2)
(check= "round" (round 2.5) 3)

; Trigonometric and hyperbolic wrappers.
(check-near "sin 0" (sin 0) 0 0.000000000000000001)
(check-near "sinh 0" (sinh 0) 0 0.000000000000000001)
(check-near "cos 0" (cos 0) 1 0.000000000000000001)
(check-near "cosh 0" (cosh 0) 1 0.000000000000000001)
(check-near "tan 0" (tan 0) 0 0.000000000000000001)
(check-near "tanh 0" (tanh 0) 0 0.000000000000000001)
(check-near "atan 0" (atan 0) 0 0.000000000000000001)
(check-near "atan2 y=0 x=1" (atan 0 1) 0 0.000000000000000001)
(check-near "asin 0" (asin 0) 0 0.000000000000000001)
(check-near "asinh inverse" (sinh (asinh 2)) 2 0.0000000000001)
(check-near "acos 1" (acos 1) 0 0.000000000000000001)
(check-near "acosh inverse" (cosh (acosh 2)) 2 0.0000000000001)
(check-near "atanh inverse" (tanh (atanh 0.5)) 0.5 0.0000000000001)
(check-near "sech 0" (sech 0) 1 0.000000000000000001)
(check-near "csch reciprocal" (* (csch 1) (sinh 1)) 1 0.000000000000000001)
(check-near "coth reciprocal" (* (coth 1) (tanh 1)) 1 0.0000000000001)
(check-near "asech inverse" (sech (asech 0.5)) 0.5 0.0000000000001)
(check-near "acsch inverse" (csch (acsch 2)) 2 0.0000000000001)
(check-near "acoth inverse" (coth (acoth 2)) 2 0.0000000000001)
(check-near "sec 0" (sec 0) 1 0.000000000000000001)
(check-near "csc reciprocal" (* (csc 1) (sin 1)) 1 0.000000000000000001)
(check-near "cot reciprocal" (* (cot 1) (tan 1)) 1 0.000000000000000001)
(check-near "asec inverse" (sec (asec 2)) 2 0.0000000000001)
(check-near "acsc inverse" (csc (acsc 2)) 2 0.0000000000001)
(check-near "acot inverse" (tan (acot 1)) 1 0.0000000000001)

; Output functions are skipped so the test report remains clean.
(check-error "error throws" (error "core-error"))

; Definitions, macros, scope, procedures, and special forms.
(def core-value 10)
(check= "def value" core-value 10)
(set! core-value 12)
(check= "set! value" core-value 12)
(def (core-add2 x) (+ x 2))
(check= "def procedure" (core-add2 5) 7)
(set! (core-add2 x) (+ x 3))
(check= "set! procedure" (core-add2 5) 8)
(check= "let binding" (let ([a 2] [b 3]) (+ a b)) 5)
(check= "lambda call through apply" (apply (lambda (x y) (+ x y)) 4 5) 9)
(check= "apply builtin procedure" (apply + 1 2 3) 6)
(check= "act builtin procedure list" (act + (list 1 2 3)) 6)

(def-macro (core-double x) (+ x x))
(check= "def-macro expansion" (core-double 4) 8)
(check= "macro? true" (macro? core-double) true)
(set-macro! (core-double x) (* x 2))
(check= "set-macro! expansion" (core-double 5) 10)

(def core-undef 1)
(check= "undef before" core-undef 1)
(undef core-undef)
(check= "undef after leaves symbol" (symbol? core-undef) true)

(check= "> comparison" (> 3 2) true)
(check= "< comparison" (< 2 3) true)
(check= "= comparison" (= 2 2) true)
(check= "/= comparison" (/= 2 3) true)
(check= ">= comparison" (>= 3 3) true)
(check= "<= comparison" (<= 3 3) true)
(check= "if true" (if true 1 2) 1)
(check= "if false" (if false 1 2) 2)
(check= "if no else false" (if false 1) nil)
(check= "when true" (when true 1) 1)
(check= "unless false" (unless false 2) 2)
(check= "cond branch" (cond [(> 1 2) 1] [(< 1 2) 2] [else 3]) 2)
(check= "try success" (try 4 (catch e 5)) 4)
(check= "try catch" (try (error "x") (catch e (++ "caught-" e))) "caught-x")
(check= "begin returns last" (begin 1 2 3) 3)
(def loop-i 0)
(def loop-sum 0)
(while (< loop-i 4)
    (begin
        (set! loop-sum (+ loop-sum loop-i))
        (set! loop-i (+ loop-i 1))))
(check= "while loop" loop-sum 6)

; Boolean logic and random/time/sleep.
(check= "and all true" (and true true true) true)
(check= "and has false" (and true false true) false)
(check= "or has true" (or false true false) true)
(check= "or all false" (or false false) false)
(check= "not true" (not true) false)
(check= "random one arg deterministic" (random 1) 0)
(check= "random two arg deterministic" (random 5 6) 5)
(check= "sleep zero returns nil" (sleep 0) nil)
(check= "time returns int" (int? (time)) true)

; Lists and sequence helpers.
(def xs (list 3 1 2 1))
(check= "list creates list" xs (list 3 1 2 1))
(check= "list-contains true" (list-contains xs 2) true)
(check= "list-index" (list-index xs 1) 1)
(check= "list-index-last" (list-index-last xs 1) 3)
(check= "list-get" (list-get xs 0) 3)
(check= "list-set copy" (list-set xs 0 9) (list 9 1 2 1))
(check= "list-set copy keeps original" xs (list 3 1 2 1))
(check= "list-remove copy" (list-remove xs 1) (list 3 2 1))
(check= "list-add append copy" (list-add xs 4) (list 3 1 2 1 4))
(check= "list-add insert copy" (list-add xs 1 9) (list 3 9 1 2 1))
(check= "head" (head xs) 3)
(check= "last" (last xs) 1)
(check= "tail" (tail xs) (list 1 2 1))
(check= "init" (init xs) (list 3 1 2))
(check= "length list" (length xs) 4)
(check= "list-sub" (list-sub xs 1 3) (list 1 2))
(check= "reverse copy" (reverse xs) (list 1 2 1 3))
(check= "sort copy" (sort xs) (list 1 1 2 3))
(check= "++ list concat" (++ (list 1 2) (list 3) 4) (list 1 2 3 4))
(check= "map" (map (lambda (x) (* x 2)) (list 1 2 3)) (list 2 4 6))
(def each-sum 0)
(for-each (lambda (x) (set! each-sum (+ each-sum x))) (list 1 2 3))
(check= "for-each" each-sum 6)
(check= "foldr" (foldr + 0 (list 1 2 3)) 6)
(check= "foldr order" (foldr (lambda (x acc) (++ x acc)) "z" (list 1 2 3)) "123z")
(check= "foldl" (foldl + 0 (list 1 2 3)) 6)
(check= "foldl order" (foldl (lambda (acc x) (++ acc x)) "z" (list 1 2 3)) "z123")
(check= "filter" (filter (lambda (x) (> x 1)) (list 1 2 3)) (list 2 3))
(check= "range one arg" (range 3) (list 0 1 2))
(check= "range two args" (range 1 4) (list 1 2 3))
(check= "range with step" (range 1 7 2) (list 1 3 5))
(check= "range with negative step" (range 5 1 -2) (list 5 3))

(def mut (list 1 2))
(list-add! mut 3)
(check= "list-add! append mutates" mut (list 1 2 3))
(list-add! mut 1 9)
(check= "list-add! insert mutates" mut (list 1 9 2 3))
(list-set! mut 0 7)
(check= "list-set! mutates" mut (list 7 9 2 3))
(list-remove! mut 2)
(check= "list-remove! mutates" mut (list 7 9 3))
(reverse! mut)
(check= "reverse! mutates" mut (list 3 9 7))
(sort! mut)
(check= "sort! mutates" mut (list 3 7 9))
(list-sub! mut 1 3)
(check= "list-sub! mutates" mut (list 7 9))

; Strings, symbols, conversion, and string helpers.
(check= "++ string concat" (++ "a" 1 "b") "a1b")
(check= "string->number" (string->number "12.5") 12.5)
(check= "string->bool true" (string->bool "true") true)
(check= "string->bool false" (string->bool "no") false)
(check= "string->symbol type" (symbol? (string->symbol "abc")) true)
(check= "->string number" (->string 12) "12")
(check= "string->list" (string->list "abc") (list "a" "b" "c"))
(check= "char->unicode" (char->unicode "A") 65)
(check= "unicode->char" (unicode->char 65) "A")
(check= "length string" (length "abcd") 4)
(check= "string-split" (string-split "a,b,c" ",") (list "a" "b" "c"))
(check= "string-split-regex" (string-split-regex "a1b2c" "[0-9]") (list "a" "b" "c"))
(check= "string-trim" (string-trim "  abc  ") "abc")
(check= "string-trim-left" (string-trim-left "  abc  ") "abc  ")
(check= "string-trim-right" (string-trim-right "  abc  ") "  abc")
(check= "string-upper" (string-upper "Abc") "ABC")
(check= "string-lower" (string-lower "Abc") "abc")
(check= "string-replace" (string-replace "a-b-a" "a" "x") "x-b-x")
(check= "string-replace-regex" (string-replace-regex "a1b2" "[0-9]" "x") "axbx")
(check= "string-index" (string-index "banana" "na") 2)
(check= "string-index-last" (string-index-last "banana" "na") 4)
(check= "string-contains" (string-contains "banana" "nan") true)
(check= "string-match" (string-match "abc123" "[a-z]+[0-9]+") true)
(check= "string-empty?" (string-empty? "") true)
(check= "string-starts-with" (string-starts-with "abc" "ab") true)
(check= "string-ends-with" (string-ends-with "abc" "bc") true)
(check= "string-get" (string-get "abc" 1) "b")
(check= "string-sub from" (string-sub "abcd" 1) "bcd")
(check= "string-sub range" (string-sub "abcd" 1 3) "bc")

; Tables.
(def tbl (table))
(check= "table? new" (table? tbl) true)
(check= "length empty table" (length tbl) 0)
(check= "table-put copy" (table-get (table-put tbl "a" 1) "a") 1)
(check= "table-put copy keeps original" (table-contains-key tbl "a") false)
(table-put! tbl "a" 1)
(table-put! tbl "b" 2)
(check= "table-put! mutates" (table-get tbl "a") 1)
(check= "table-contains-key" (table-contains-key tbl "b") true)
(check= "table-contains-value" (table-contains-value tbl 2) true)
(check= "length table" (length tbl) 2)
(check= "table-keys length" (length (table-keys tbl)) 2)
(check= "table-remove copy" (table-contains-key (table-remove tbl "a") "a") false)
(check= "table-remove copy keeps original" (table-contains-key tbl "a") true)
(table-remove! tbl "a")
(check= "table-remove! mutates" (table-contains-key tbl "a") false)

; Min/max and type predicates.
(check= "max" (max 1 5 3) 5)
(check= "min" (min 1 5 3) 1)
(check= "bool?" (bool? true) true)
(check= "float?" (float? 1.2) true)
(check= "int?" (int? 1) true)
(check= "list?" (list? xs) true)
(check= "number?" (number? 1.2) true)
(check= "procedure?" (procedure? +) true)
(check= "string?" (string? "x") true)
(check= "symbol?" (symbol? (string->symbol "x")) true)
(check= "table?" (table? tbl) true)
(check= "word?" (word? nil) true)
(check= "nil?" (nil? nil) true)
(check= "zero?" (zero? 0) true)
(check= "type bool" (type true) "bool")

; Error paths.
(check-error "divide by zero" (/ 1 0))
(check-error "mod by zero" (mod 1 0))
(check-error "rem by zero" (rem 1 0))
(check-error "sqrt negative" (sqrt -1))
(check-error "pow zero negative exponent" (pow 0 -1))
(check-error "log non-positive value" (log 0))
(check-error "asin out of range" (asin 2))
(check-error "acos out of range" (acos -2))
(check-error "atanh out of range" (atanh 1))
(check-error "acosh out of range" (acosh 0.5))
(check-error "csch zero" (csch 0))
(check-error "coth zero" (coth 0))
(check-error "asech out of range" (asech 2))
(check-error "acsch zero" (acsch 0))
(check-error "acoth out of range" (acoth 1))
(check-error "asec out of range" (asec 0.5))
(check-error "acsc out of range" (acsc 0.5))
(check-error "range zero step" (range 1 3 0))
(check-error "list-get out of bounds" (list-get xs 99))
(check-error "list-remove out of bounds" (list-remove xs 99))
(check-error "list-sub invalid range" (list-sub xs 3 1))
(check-error "string-get out of bounds" (string-get "abc" 99))
(check-error "string-sub invalid range" (string-sub "abc" 2 1))

; These Core entries require stdin or terminate the process, so this batch test
; records them without executing them.
(skip "read-line" "requires stdin and may block")
(skip "read-int" "requires stdin and may block")
(skip "read-float" "requires stdin and may block")
(skip "read-bool" "requires stdin and may block")
(skip "read" "requires stdin and may block")
(skip "exit" "terminates the JVM")
(skip "print" "writes directly to stdout")
(skip "println" "writes directly to stdout")
(skip "error-print" "writes directly to stderr")
(skip "error-println" "writes directly to stderr")
(skip "newline" "writes directly to stdout")
(skip "error-newline" "writes directly to stderr")

(println "== summary ==")
(println "total=" total ", passed=" passed ", failed=" failed ", skipped=" skipped)
(when (> failed 0)
    (println "Some tests failed. See [FAIL] lines above."))
